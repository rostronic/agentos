# AgentOS credentials — copy this file to `.env` and fill in your keys.
#
#   cp config/credentials/.env.example config/credentials/.env
#
# `.env` is gitignored — never commit it. The orchestrator loads these into the
# environment via agentos.core.config (KEY=VALUE, no overwrite of already-set vars).
#
# Run `agentos init` for a guided setup that writes config/{user,settings,budgets}.yaml
# and tells you which of the keys below you actually need.

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — only if you run the metered API provider (default_provider: claude_api)
# ─────────────────────────────────────────────────────────────────────────────
# If you use the default `claude_code` provider (your Max/Pro subscription via the
# `claude` CLI), you do NOT need this — leave it blank. It is required only when
# default_provider is `claude_api` in config/settings.yaml.
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — notifications (Telegram). Leave blank to disable.
# ─────────────────────────────────────────────────────────────────────────────
# Bot token from @BotFather; chat id is where the bot sends you messages.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — email digest (Gmail SMTP over STARTTLS). Leave blank to disable.
# ─────────────────────────────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password) for EMAIL_PASSWORD.
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_TO=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — alternate / test inference backends
# ─────────────────────────────────────────────────────────────────────────────
# OpenAI provider (if you route any agent through it).
OPENAI_API_KEY=
# Ollama for fully-local, no-cost testing (default_provider: ollama). Point at a
# running Ollama server; no key needed.
OLLAMA_BASE_URL=http://localhost:11434
