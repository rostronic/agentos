{
  "_comment": "Add the 'agentos' entry to your Claude Desktop MCP config.",
  "_path": "~/Library/Application Support/Claude/claude_desktop_config.json",
  "_instruction": "Paste the 'agentos' key inside the 'mcpServers' object (replace ~/agentos with your absolute agentos path), then restart Claude Desktop.",

  "mcpServers": {
    "agentos": {
      "command": "~/agentos/orchestrator/.venv/bin/python",
      "args": ["-m", "agentos.entrypoints.mcp_server"],
      "cwd": "~/agentos/orchestrator",
      "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
      }
    }
  }
}
